:80 {
    log {
        level INFO
    }

    # 启用 Gzip 压缩，显著减少传输体积
    encode gzip

    # 后端 API 反向代理
    # 匹配 /api/health 并重写为 /health
    @api_health path /api/health
    handle @api_health {
        rewrite * /health
        reverse_proxy backend:8000
    }

    # 匹配所有 /api/* 请求
    @api path /api/*
    handle @api {
        reverse_proxy backend:8000
    }

    # 前端静态资源反向代理
    # 所有其他请求转发给 frontend 服务
    handle {
        # 静态资源长期缓存策略
        # 注意：前端构建工具通常会为静态文件添加哈希，所以可以安全地长期缓存
        @static path /static/*
        header @static Cache-Control "public, max-age=31536000"

        reverse_proxy frontend:80
    }
}
