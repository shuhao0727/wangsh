:80 {
    log {
        level INFO
    }

    # 启用 Gzip 压缩
    encode gzip

    # 纯静态文件服务
    # 不再包含后端代理逻辑，实现解耦
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server

        # 静态资源缓存控制
        @static path /static/*
        header @static Cache-Control "public, max-age=31536000"
    }
}
