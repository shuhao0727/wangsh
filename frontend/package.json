{
  "name": "wangsh-frontend",
  "version": "1.5.5",
  "private": true,
  "description": "WangSh 项目前端应用 - React + TypeScript + Vite",
  "author": "WangSh Team",
  "license": "MIT",
  "homepage": "/",
  "scripts": {
    "predev": "node scripts/copy-pyodide.js",
    "prebuild": "node scripts/copy-pyodide.js",
    "dev": "vite --mode development",
    "build": "tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "start": "vite --mode development",
    "test": "echo \"TODO: migrate to vitest\" && exit 1",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "type-check": "tsc --noEmit",
    "pythonlab:smoke": "node scripts/pythonlab-debug-smoke.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "ui:audit:json": "node scripts/ui-audit.mjs --json",
    "ui:audit:ci": "node scripts/ui-audit.mjs --ci --baseline scripts/ui-audit-baseline.json",
    "ui:page:report": "node scripts/ui-page-workflow.mjs",
    "ui:page:verify": "node scripts/ui-page-workflow.mjs --with-type-check",
    "ui:migration:metrics": "node scripts/ui-migration-metrics.mjs",
    "ui:migration:gate": "npm run type-check && npm run build && npm run ui:migration:metrics"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@hpcc-js/wasm": "^2.21.0",
    "@monaco-editor/react": "^4.7.0",
    "@myriaddreamin/typst-ts-renderer": "^0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.7.0-rc2",
    "@myriaddreamin/typst.ts": "^0.7.0-rc2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/dagre": "^0.7.53",
    "@types/dompurify": "^3.0.5",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.7",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "eventsource-parser": "^1.1.2",
    "katex": "^0.16.11",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^4.10.38",
    "pyodide": "0.25.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.3",
    "playwright": "^1.54.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
}
