# ============================================
# WangSh 生产环境配置示例
# 复制此文件为 .env 并根据实际情况修改
# ============================================

# ==================== 项目信息 ====================
PROJECT_NAME=WangSh
APP_VERSION=1.1.1
API_V1_STR=/api/v1

# ==================== 部署环境 ====================
DEPLOYMENT_ENV=production
DEBUG=False
LOG_LEVEL=INFO

# ==================== 镜像信息 (可选) ====================
DOCKER_REGISTRY=docker.io
DOCKERHUB_NAMESPACE=shuhao07
IMAGE_TAG=1.1.1
IMAGE_NAME_BACKEND=wangsh-backend
IMAGE_NAME_FRONTEND=wangsh-frontend
IMAGE_NAME_WORKER=wangsh-typst-worker

# ==================== 后端服务配置 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=False

# ==================== 安全配置 (生产环境务必修改) ====================
SECRET_KEY=prod_change_me_to_a_very_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ==================== 超级管理员 ====================
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=prod_admin_password_change_me
SUPER_ADMIN_FULL_NAME=系统超级管理员

# ==================== 智能体 ====================
# 使用 base64 生成: openssl rand -base64 32
AGENT_API_KEY_ENCRYPTION_KEY=prod_change_me_to_a_base64_key

# ==================== 前端服务配置 ====================
FRONTEND_PORT=6608
WEB_PORT=6608
REACT_APP_ENV=production
# Docker 部署通常使用相对路径 /api/v1 (通过网关转发)
# 如果是分离部署，请填写真实的后端 API 地址，如 https://api.your-domain.com/api/v1
REACT_APP_API_URL=/api/v1
REACT_APP_VERSION=1.1.1
FRONTEND_HOT_RELOAD=False

# ==================== CORS 配置 ====================
# 允许访问后端的域名列表
CORS_ORIGINS=["http://localhost:6608","https://your-domain.com"]

# ==================== 数据库 ====================
# Docker 内部网络使用主机名 "postgres"
# 如果是本地开发连接 Docker 数据库，使用 "127.0.0.1"
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=prod_postgres_password_change_me
POSTGRES_DB=wangsh_db
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_STATEMENT_TIMEOUT=60000
DATABASE_DRIVER=asyncpg

# ==================== Redis ====================
# Docker 内部网络使用主机名 "wangsh-redis" (注意 docker-compose.yml 中的 container_name)
# 如果是本地开发连接 Docker Redis，使用 "127.0.0.1"
REDIS_HOST=wangsh-redis
REDIS_PORT=6379
REDIS_CONTAINER_NAME=wangsh-redis
REDIS_CONNECT_TIMEOUT=5
REDIS_DB_CACHE=0

# ==================== PythonLab (沙箱环境) ====================
PYTHONLAB_SANDBOX_IMAGE=shuhao07/pythonlab-sandbox:py311
PYTHONLAB_WORKSPACE_ROOT=/tmp/pythonlab/workspaces
PYTHONLAB_DEBUGPY_PORT=5678
PYTHONLAB_DEFAULT_CPU_QUOTA=50000
PYTHONLAB_DEFAULT_MEMORY_MB=32

# ==================== Typst (文档编译) ====================
TYPST_COMPILE_MAX_CONCURRENCY=2
TYPST_COMPILE_USE_CELERY=true

# ==================== 其他 ====================
TIMEZONE=Asia/Shanghai
UPLOAD_FOLDER=./uploads
DATA_DIR=./data

# ==================== 会话/IP 控制 (安全策略) ====================
# 是否信任反代传入的 X-Forwarded-For（建议生产开启）
AUTH_TRUST_X_FORWARDED_FOR=true
# 解析客户端IP的请求头优先级
AUTH_IP_HEADER_ORDER=X-Forwarded-For,X-Real-IP,Forwarded,Remote-Addr
# 同一IP只允许一个用户在线（机房/NAT环境建议关闭或配合X-Forwarded-For使用）
AUTH_USER_UNIQUE_PER_IP=true
# 同一用户仅绑定一个IP，后登录会踢前一个
AUTH_IP_UNIQUE_PER_USER=true
# 是否对每个请求都强校验IP（默认false；在NAT场景建议关闭）
AUTH_ENFORCE_SAME_IP_PER_REQUEST=false
# 会话记录TTL（秒），0表示与访问令牌/学生会话TTL对齐
AUTH_SESSION_TTL_SECONDS=0
